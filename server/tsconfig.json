{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "generated", "scripts", "seed"]
}
