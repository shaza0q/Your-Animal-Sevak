# Copy this to .env.docker and fill in real values before running docker compose.
#
# Start just the database:
#   docker compose --env-file .env.docker up -d
#
# Start database + pgAdmin (GUI):
#   docker compose --env-file .env.docker --profile tools up -d
#
# NOTE: If you change POSTGRES_USER, also update docker/pgadmin/servers.json
#       so pgAdmin can auto-connect.

POSTGRES_USER=animal_sevak
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=animal_sevak
POSTGRES_PORT=5432

PGADMIN_EMAIL=admin@animalsevak.local
PGADMIN_PASSWORD=changeme
PGADMIN_PORT=5050
